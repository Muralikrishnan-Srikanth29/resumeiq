# Copy to .env for local development. Never commit the real .env file.

# --- App ---
ENVIRONMENT=development
DEBUG=true

# --- CORS: comma-separated list of allowed frontend origins ---
ALLOWED_ORIGINS=http://localhost:3000

# --- Supabase ---
# Project Settings > API in your Supabase dashboard
SUPABASE_URL=https://your-project-ref.supabase.co
# service_role key — NOT the anon/public key. Full table access; backend-only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=resumes

# --- Gemini ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=4096

# --- Rate limiting ---
RATE_LIMIT_ANALYSIS_PER_HOUR=10
RATE_LIMIT_UPLOAD_PER_HOUR=20

# --- File upload constraints ---
MAX_FILE_SIZE_MB=5
MAX_RESUME_TEXT_CHARS=50000
MAX_JD_TEXT_CHARS=20000
MIN_RESUME_TEXT_CHARS=200
